---
import Layout from '../../layouts/Layout.astro';
import SiteIcon from '../system/SiteIcon.astro';
import '../../styles/examples.css';

interface NavItem {
	label: string;
	href: string;
}

interface Props {
	siteName: string;
	pageTitle?: string;
	description: string;
	variant:
		| 'northstar'
		| 'elm-ivory'
		| 'harborcare'
		| 'fieldstone'
		| 'briar-stone'
		| 'brightpath'
		| 'saffron-house'
		| 'aureline'
		| 'gallery';
	tagline?: string;
	navItems?: NavItem[];
	homeUrl?: string;
	primaryLabel?: string;
	primaryUrl?: string;
	footerNote?: string;
}

const {
	siteName,
	pageTitle = 'Preview',
	description,
	variant,
	tagline = '',
	navItems = [],
	homeUrl = '/',
	primaryLabel = '',
	primaryUrl = '',
	footerNote = 'Public Astro demo built from a reusable capsule system.',
} = Astro.props;

const title = `${siteName} — ${pageTitle}`;
const variantIcons = {
	northstar: 'monitoring',
	'elm-ivory': 'auto_awesome',
	harborcare: 'task_alt',
	fieldstone: 'layers',
	'briar-stone': 'flag',
	brightpath: 'rocket_launch',
	'saffron-house': 'travel_explore',
	aureline: 'inventory_2',
	gallery: 'grid_view',
} as const;
const variantIcon = variantIcons[variant];
---

<Layout
	lang="en"
	title={title}
	description={description}
	siteName={siteName}
>
	<div class:list={['example-site', `example-site--${variant}`]}>
		<header class="example-site__header">
			<div class="example-site__header-inner bw-shell">
				<div class="example-site__brand">
					<a class="example-site__brand-mark" href={homeUrl}>
						<span class="example-site__brand-row">
							<SiteIcon name={variantIcon} size="sm" className="example-site__brand-icon" />
							<span class="example-site__brand-name">{siteName}</span>
						</span>
						{tagline ? <span class="example-site__tagline">{tagline}</span> : null}
					</a>
				</div>

				{navItems.length ? (
					<nav class="example-site__nav" aria-label={`${siteName} navigation`}>
						{navItems.map((item) => (
							<a class="example-site__nav-link" href={item.href}>{item.label}</a>
						))}
					</nav>
				) : null}

				{primaryLabel ? (
					<a class="example-site__header-cta" href={primaryUrl || '#contact'}>
						<span>{primaryLabel}</span>
						<SiteIcon name="arrow_outward" size="sm" className="example-site__header-cta-icon" />
					</a>
				) : null}
			</div>
		</header>

		<main class="example-site__main">
			<slot />
		</main>

		<footer class="example-site__footer">
			<div class="example-site__footer-inner bw-shell">
				<div class="example-site__footer-copy">
					<p class="example-site__footer-name">{siteName}</p>
					<p class="example-site__footer-note">{footerNote}</p>
				</div>
				<div class="example-site__footer-side">
					<p class="example-site__footer-meta">Open demo routes for public preview</p>
					<div class="example-site__social" aria-label="Available social icons">
						<span class="example-site__social-item" title="Instagram icon sample">
							<SiteIcon name="instagram" size="sm" className="example-site__social-icon" />
						</span>
						<span class="example-site__social-item" title="LinkedIn icon sample">
							<SiteIcon name="linkedin" size="sm" className="example-site__social-icon" />
						</span>
						<span class="example-site__social-item" title="Twitter icon sample">
							<SiteIcon name="twitter" size="sm" className="example-site__social-icon" />
						</span>
					</div>
				</div>
			</div>
		</footer>
	</div>
</Layout>
