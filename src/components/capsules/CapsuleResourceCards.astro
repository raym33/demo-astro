---
import SiteIcon from '../system/SiteIcon.astro';

interface ResourceCardItem {
	eyebrow?: string;
	title?: string;
	description?: string;
	meta?: string;
	ctaLabel?: string;
	ctaUrl?: string;
	tone?: 'neutral' | 'accent' | 'ink';
}

interface Props {
	align?: 'wide' | 'full';
	eyebrow?: string;
	heading?: string;
	intro?: string;
	layout?: 'grid' | 'stacked';
	theme?: 'paper' | 'ink' | 'signal';
	surface?: 'soft' | 'hard' | 'outline';
	items: ResourceCardItem[];
}

const {
	align = 'wide',
	eyebrow = '',
	heading = '',
	intro = '',
	layout = 'grid',
	theme = 'paper',
	surface = 'soft',
	items = [],
} = Astro.props;
---

{items.length ? (
	<section class:list={['bw-shell', align === 'full' ? 'is-full' : 'is-wide']}>
		<div
			class:list={[
				'bw-resource-cards',
				`is-layout-${layout}`,
				`is-theme-${theme}`,
				`is-surface-${surface}`,
				`has-${items.length}-items`,
			]}
		>
			<div class="bw-resource-cards__inner">
				{eyebrow || heading || intro ? (
					<div class="bw-resource-cards__header">
						{eyebrow ? <p class="bw-resource-cards__eyebrow">{eyebrow}</p> : null}
						{heading ? <h2 class="bw-resource-cards__heading">{heading}</h2> : null}
						{intro ? <div class="bw-resource-cards__intro" set:html={intro} /> : null}
					</div>
				) : null}

				<div class="bw-resource-cards__grid">
					{items.map((item, index) => {
						const ctaLabel = item.ctaLabel || (item.ctaUrl ? 'Open' : '');
						return (
							<article
								class:list={[
									'bw-resource-cards__item',
									`is-tone-${item.tone || 'neutral'}`,
								]}
							>
								<div class="bw-resource-cards__card">
									<div class="bw-resource-cards__meta-row">
										<span class="bw-resource-cards__index">
											{String(index + 1).padStart(2, '0')}
										</span>
										{item.eyebrow ? (
											<p class="bw-resource-cards__item-eyebrow">{item.eyebrow}</p>
										) : null}
									</div>

									<div class="bw-resource-cards__copy">
										{item.title ? (
											<h3 class="bw-resource-cards__title">{item.title}</h3>
										) : null}
										{item.description ? (
											<div
												class="bw-resource-cards__description"
												set:html={item.description}
											/>
										) : null}
									</div>

									<div class="bw-resource-cards__footer">
										{item.meta ? (
											<p class="bw-resource-cards__meta">{item.meta}</p>
										) : (
											<span></span>
										)}

										{ctaLabel ? (
											item.ctaUrl ? (
												<a class="bw-resource-cards__cta" href={item.ctaUrl}>
													<span>{ctaLabel}</span>
													<SiteIcon
														name="arrow_outward"
														size="sm"
														className="bw-resource-cards__cta-icon"
													/>
												</a>
											) : (
												<span class="bw-resource-cards__cta">
													<span>{ctaLabel}</span>
												</span>
											)
										) : null}
									</div>
								</div>
							</article>
						);
					})}
				</div>
			</div>
		</div>
	</section>
) : null}

<style>
	.bw-resource-cards {
		--resource-bg: #f5efe8;
		--resource-card: rgba(255, 255, 255, 0.72);
		--resource-ink: #302925;
		--resource-muted: rgba(48, 41, 37, 0.72);
		--resource-line: rgba(48, 41, 37, 0.12);
		--resource-accent: #b8643a;
		--resource-shadow: 0 18px 44px rgba(48, 41, 37, 0.08);
		position: relative;
		overflow: clip;
		border-radius: clamp(1rem, 2.5vw, 1.8rem);
		background: var(--resource-bg);
		color: var(--resource-ink);
	}

	.bw-resource-cards.is-theme-ink {
		--resource-bg: #151313;
		--resource-card: rgba(248, 240, 236, 0.06);
		--resource-ink: #f7efe8;
		--resource-muted: rgba(247, 239, 232, 0.72);
		--resource-line: rgba(247, 239, 232, 0.12);
		--resource-accent: #efb989;
		--resource-shadow: 0 22px 48px rgba(0, 0, 0, 0.24);
	}

	.bw-resource-cards.is-theme-signal {
		--resource-bg: #f4ddcc;
		--resource-card: rgba(255, 248, 242, 0.76);
		--resource-ink: #37231b;
		--resource-muted: rgba(55, 35, 27, 0.74);
		--resource-line: rgba(55, 35, 27, 0.12);
		--resource-accent: #c24e27;
		--resource-shadow: 0 20px 46px rgba(103, 56, 35, 0.12);
	}

	.bw-resource-cards.is-surface-hard {
		--resource-card: rgba(255, 255, 255, 0.9);
	}

	.bw-resource-cards.is-theme-ink.is-surface-hard {
		--resource-card: rgba(248, 240, 236, 0.1);
	}

	.bw-resource-cards.is-theme-signal.is-surface-hard {
		--resource-card: rgba(255, 247, 239, 0.92);
	}

	.bw-resource-cards.is-surface-outline {
		background: transparent;
		border: 1px solid var(--resource-line);
	}

	.bw-resource-cards__inner {
		display: grid;
		gap: clamp(1.2rem, 3vw, 2.25rem);
		padding: clamp(1.3rem, 4vw, 3rem);
	}

	.bw-resource-cards__header {
		display: grid;
		gap: 1rem;
		align-content: start;
	}

	.bw-resource-cards__eyebrow {
		margin: 0;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--resource-accent);
	}

	.bw-resource-cards__heading {
		margin: 0;
		max-width: 18ch;
		font-family: var(--bw-font-display);
		font-size: clamp(2rem, 4.8vw, 3.15rem);
		line-height: 1.05;
		letter-spacing: -0.04em;
		text-wrap: balance;
	}

	.bw-resource-cards__intro {
		max-width: 50rem;
		font-size: clamp(1rem, 2vw, 1.05rem);
		line-height: 1.72;
		color: var(--resource-muted);
	}

	.bw-resource-cards__intro :first-child {
		margin-top: 0;
	}

	.bw-resource-cards__intro :last-child {
		margin-bottom: 0;
	}

	.bw-resource-cards__grid {
		display: grid;
		gap: 1rem;
	}

	.bw-resource-cards__item {
		--resource-item-bg: var(--resource-card);
		--resource-item-ink: var(--resource-ink);
		--resource-item-muted: var(--resource-muted);
		--resource-item-line: var(--resource-line);
		display: grid;
		border: 1px solid var(--resource-item-line);
		border-radius: 1.2rem;
		background: var(--resource-item-bg);
		color: var(--resource-item-ink);
		box-shadow: var(--resource-shadow);
	}

	.bw-resource-cards__item.is-tone-accent {
		--resource-item-bg: linear-gradient(160deg, #f3d8c5 0%, #faede4 100%);
		--resource-item-line: transparent;
		--resource-item-muted: rgba(55, 35, 27, 0.74);
	}

	.bw-resource-cards.is-theme-ink .bw-resource-cards__item.is-tone-accent {
		--resource-item-bg: linear-gradient(160deg, #513e36 0%, #261f1d 100%);
		--resource-item-muted: rgba(247, 239, 232, 0.76);
	}

	.bw-resource-cards__item.is-tone-ink {
		--resource-item-bg: #1d1716;
		--resource-item-ink: #f8efe8;
		--resource-item-muted: rgba(248, 239, 232, 0.72);
		--resource-item-line: rgba(248, 239, 232, 0.12);
	}

	.bw-resource-cards.is-theme-ink .bw-resource-cards__item.is-tone-ink {
		--resource-item-bg: rgba(248, 240, 236, 0.12);
	}

	.bw-resource-cards.is-surface-outline .bw-resource-cards__item {
		box-shadow: none;
	}

	.bw-resource-cards__card {
		display: grid;
		gap: 1rem;
		height: 100%;
		padding: clamp(1rem, 2.6vw, 1.35rem);
	}

	.bw-resource-cards__meta-row,
	.bw-resource-cards__footer {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.7rem 1rem;
	}

	.bw-resource-cards__index,
	.bw-resource-cards__item-eyebrow,
	.bw-resource-cards__meta {
		margin: 0;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.bw-resource-cards__index,
	.bw-resource-cards__item-eyebrow {
		color: var(--resource-accent);
	}

	.bw-resource-cards__meta {
		color: var(--resource-item-muted);
	}

	.bw-resource-cards__copy {
		display: grid;
		gap: 0.8rem;
		align-content: start;
	}

	.bw-resource-cards__title {
		margin: 0;
		font-family: var(--bw-font-display);
		font-size: clamp(1.4rem, 3vw, 2rem);
		line-height: 1.08;
		letter-spacing: -0.03em;
		text-wrap: balance;
	}

	.bw-resource-cards__description {
		font-size: 0.98rem;
		line-height: 1.7;
		color: var(--resource-item-muted);
	}

	.bw-resource-cards__description :first-child {
		margin-top: 0;
	}

	.bw-resource-cards__description :last-child {
		margin-bottom: 0;
	}

	.bw-resource-cards__cta {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: inherit;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		text-decoration: none;
	}

	.bw-resource-cards__cta-icon {
		transition: transform 180ms ease;
	}

	.bw-resource-cards__cta:hover .bw-resource-cards__cta-icon {
		transform: translateX(2px) translateY(-1px);
	}

	@media (min-width: 900px) {
		.bw-resource-cards__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.bw-resource-cards.is-layout-stacked .bw-resource-cards__grid {
			grid-template-columns: 1fr;
		}
	}

	@media (min-width: 1180px) {
		.bw-resource-cards__inner {
			grid-template-columns: minmax(16rem, 0.85fr) minmax(0, 1.15fr);
			align-items: start;
		}
	}
</style>
